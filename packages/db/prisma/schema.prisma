generator client {
   provider = "prisma-client"
   output   = "../generated/prisma"
}

datasource db {
   provider = "postgresql"
}

enum Language {
   javascript
   typescript
   python
   java
   go
   csharp
   php
}

enum Status {
   pending
   running
   failed
   accepted
}

model Candidate {
   clerk_id        String   @id
   email           String   @unique
   email_verified  Boolean?
   first_name      String
   last_name       String
   phone           String?
   profile_pic_key String?
   bio             String?
   resume_obj_key  String?
   gh_url          String?
   lc_url          String?
   cf_url          String?
   wakatime_api    String?

   created_at DateTime @default(now())
   updated_at DateTime @updatedAt

   leaderboards Leaderboard[]
   submissions  Submission[]
}

model Recruiter {
   clerk_id String @id

   email               String   @unique
   email_verified      Boolean?
   company_name        String?
   company_description String?
   company_website     String?
   company_employees   Int?

   created_at DateTime @default(now())
   updated_at DateTime @updatedAt

   hiring_posts HiringPost[]
}

model HiringPost {
   id              String   @id @default(uuid())
   job_title       String
   job_description String
   requirements    String
   is_active       Boolean  @default(true)
   created_at      DateTime @default(now())
   updated_at      DateTime @updatedAt

   recruiter_id String
   recruiter    Recruiter @relation(fields: [recruiter_id], references: [clerk_id])

   contest_id String?  @unique
   contest    Contest? @relation(fields: [contest_id], references: [id])

   @@index([recruiter_id])
}

model Contest {
   id         String   @id @default(uuid())
   title      String   @unique
   deadline   DateTime
   start_time DateTime

   hiring_post                  HiringPost?
   leaderboards                 Leaderboard[]
   contest_to_challenge_mapping Contest_to_Challenge_mapping[]
}

model Contest_to_Challenge_mapping {
   id           String       @id @default(uuid())
   position     Int
   contest_id   String
   challenge_id String
   submissions  Submission[]

   contest   Contest   @relation(fields: [contest_id], references: [id], onDelete: Cascade)
   challenge Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

   @@unique([contest_id, challenge_id])
   @@unique([contest_id, position])
}

enum Difficulty {
   easy
   medium
   hard
}

enum QuestionType {
   mcq
   dsa
   project
}

model Challenge {
   id            String     @id @default(uuid())
   title         String     @unique
   max_pts       Int
   challenge_doc String
   difficulty    Difficulty @default(medium)
   question_type QuestionType

   contest_to_challenge_mapping Contest_to_Challenge_mapping[]

   mcq     MCQChallenge?
   dsa     DSAChallenge?
   project ProjectChallenge?
}

model MCQChallenge {
   id           String @id @default(uuid())
   challenge_id String @unique
   question     String
   options      Json
   correct_idx  Int

   challenge Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
}

model DSAChallenge {
   id           String @id @default(uuid())
   challenge_id String @unique

   input_format  String
   output_format String
   constraints   String
   test_cases    Json
   hidden_cases  Json

   challenge Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
}

enum Project_type {
   backend
   frontend
}

model ProjectChallenge {
   id                  String       @id @default(uuid())
   project_type        Project_type
   repo_template_url   String?
   requirements        String
   evaluation_criteria String
   test_config         Json?

   challenge_id String @unique

   challenge Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
}

model Submission {
   id              String    @id @default(uuid())
   points          Int?
   submission      String?
   selected_option Int?
   language        Language?
   status          Status
   feedback        String?
   candidate_id    String
   created_at      DateTime  @default(now())

   candidate                       Candidate                    @relation(fields: [candidate_id], references: [clerk_id])
   contest_to_challenge_mapping_id String
   contest_to_challenge_mapping    Contest_to_Challenge_mapping @relation(fields: [contest_to_challenge_mapping_id], references: [id], onDelete: Cascade)

   @@index([candidate_id])
   @@index([contest_to_challenge_mapping_id])
}

model Leaderboard {
   id           String @id @default(uuid())
   rank         Int
   contest_id   String
   candidate_id String

   contest   Contest   @relation(fields: [contest_id], references: [id], onDelete: Cascade)
   candidate Candidate @relation(fields: [candidate_id], references: [clerk_id])

   @@unique([contest_id, candidate_id])
   @@unique([contest_id, rank])
}
